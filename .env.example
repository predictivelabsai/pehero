# PostgreSQL — shared server, schemas `pehero` and `pehero_rag` will be
# created inside the target database.
DB_URL=postgresql://user:pass@host:5432/dbname

# xAI Grok (OpenAI-compatible endpoint)
XAI_API_KEY=xai-...
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-fast-reasoning
XAI_AGENT_MODEL=grok-4

# Web search for sourcing agents. Tavily is the default; EXA is fallback.
TAVILY_API_KEY=tvly-...
EXA_API_KEY=

# Baltic business registry + tax authority integrations (see docs/registry_integration.md)
# All optional — absence disables those tools.
LT_CR_API_KEY=          # Lithuania — Registrų centras (business registry)
LT_VMI_API_KEY=         # Lithuania — VMI (State Tax Inspectorate)
LV_UR_API_KEY=          # Latvia — Uzņēmumu reģistrs (business registry)
LV_VID_API_KEY=         # Latvia — VID (State Revenue Service)
EE_ARI_API_KEY=         # Estonia — Äriregister (RIK / business registry)
EE_EMTA_API_KEY=        # Estonia — EMTA (Tax & Customs Board)

# Embeddings. Default is `local` (fastembed, no API key, ~100 MB ONNX model).
# Switch to `openai` if you have OPENAI_API_KEY and want higher-quality vectors.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
OPENAI_API_KEY=

# App
APP_ENV=dev
APP_SECRET=change-me
PORT=5058
